# Server Configuration
NODE_ENV=development
PORT=8080

# Database Configuration (PostgreSQL / SQL Server / MongoDB)
POSTGRES_URL=postgresql://username:password@localhost:5432/database_name
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/dbname
MongoDB_URL=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Redis Configuration
REDIS_URL=rediss://default:password@your-redis-url:6379

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App Links
LINK_CLIENT=https://localhost:5200
LINK_SERVER=https://localhost:8080
LINK_CLIENT_PROD=your_prod_client_url
LINK_SERVER_PROD=your_prod_server_url
LINK_CLIENT_LOCAL_IP=https://192.168.1.x:5200

# Video/Audio Call (LiveKit)
LIVEKIT_API_KEY=your_livekit_key
LIVEKIT_API_SECRET=your_livekit_secret

# Authentication (Google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Authentication (GitHub)
GITHUB_CLIENT_ID_DEV=your_github_dev_id
GITHUB_CLIENT_SECRET_DEV=your_github_dev_secret
GITHUB_CLIENT_ID_PROD=your_github_prod_id
GITHUB_CLIENT_SECRET_PROD=your_github_prod_secret

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
MAIL_FROM_NAME=Pigeons
MAIL_FROM_ADDRESS=no-reply@yourdomain.com

# AI Configuration (OpenRouter & HuggingFace)
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
MODEL_AI=your_preferred_model
CHAT_MODEL=your_chat_model
AI_MODERATOR_URL=your_huggingface_moderator_url

# Push Notifications (OneSignal)
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key
